# Root .gitignore for PonteVPN
# Prevent local secrets from leaking to GitHub

# Local Secrets
.env
.env.local
.env.*
secrets/
credentials/
*.pem
*.key
*.json.private

# Database
backend/database.db
*.sqlite
*.sqlite3

# Build & System
node_modules/
.next/
__pycache__/
*.log
.DS_Store
.obsidian/
dist/
build/
.env*
logs/